# profile.d/10-userdirs.sh
# managed by ansible role marcus_grant.dotfiles.userdirs

# XDG directory (re-)definitions
{% if userdirs_xdg_bin_home | length > 0 %}
export XDG_BIN_HOME="$HOME/{{ userdirs_xdg_bin_home }}"
{% endif %}
{% if userdirs_xdg_data_home | length > 0 %}
export XDG_DATA_HOME="$HOME/{{ userdirs_xdg_data_home }}"
{% endif %}
{% if userdirs_xdg_config_home | length > 0 %}
export XDG_CONFIG_HOME="$HOME/{{ userdirs_xdg_config_home }}"
{% endif %}
{% if userdirs_xdg_cache_home | length > 0 %}
export XDG_CACHE_HOME="$HOME/{{ userdirs_xdg_cache_home }}"
{% endif %}
{% if userdirs_xdg_state_home | length > 0 %}
export XDG_STATE_HOME="$HOME/{{ userdirs_xdg_state_home }}"
{% endif %}
